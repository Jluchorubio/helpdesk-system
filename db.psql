-- Asignación de permisos por rol
INSERT INTO users.role_permissions (role_id, permission_id)
SELECT r.id, p.id
FROM users.roles r, users.permissions p
WHERE
    (r.name = 'aprendiz'      AND p.name IN ('tickets.create','tickets.view_own'))
 OR (r.name = 'instructor'    AND p.name IN ('tickets.create','tickets.view_own','inventory.view'))
 OR (r.name = 'administrativo' AND p.name IN ('tickets.view_all','inventory.view','reports.view','users.view'))
 OR (r.name = 'soporte'       AND p.name IN ('tickets.create','tickets.view_all','tickets.assign',
                                              'tickets.close','inventory.view','inventory.edit',
                                              'inventory.assign','users.view','reports.view'))
 OR (r.name = 'admin'         AND p.name IN (SELECT name FROM users.permissions));


-- ============================================================================
-- 7. SCHEMA: inventory (con soft delete universal)
-- ============================================================================

CREATE TABLE inventory.blocks (
    id              SERIAL      PRIMARY KEY,
    organization_id UUID        NOT NULL REFERENCES users.organizations(id) ON DELETE RESTRICT,
    name            VARCHAR(100) NOT NULL,
    description     TEXT,
    created_at      TIMESTAMPTZ NOT NULL DEFAULT CURRENT_TIMESTAMP,
    deleted_at      TIMESTAMPTZ,
    UNIQUE(organization_id, name)
);

CREATE TABLE inventory.environments (
    id              SERIAL      PRIMARY KEY,
    organization_id UUID        NOT NULL REFERENCES users.organizations(id) ON DELETE RESTRICT,
    block_id        INT         NOT NULL REFERENCES inventory.blocks(id) ON DELETE RESTRICT,
    name            VARCHAR(100) NOT NULL,
    capacity        SMALLINT,
    floor           SMALLINT,
    is_active       BOOLEAN     NOT NULL DEFAULT TRUE,
    created_at      TIMESTAMPTZ NOT NULL DEFAULT CURRENT_TIMESTAMP,
    updated_at      TIMESTAMPTZ,
    deleted_at      TIMESTAMPTZ,
    UNIQUE(organization_id, block_id, name)
);

CREATE TABLE inventory.equipment_types (
    id              SERIAL      PRIMARY KEY,
    organization_id UUID        NOT NULL REFERENCES users.organizations(id) ON DELETE RESTRICT,
    name            VARCHAR(100) NOT NULL,
    custom_fields   JSONB        NOT NULL DEFAULT '{}',
    created_at      TIMESTAMPTZ NOT NULL DEFAULT CURRENT_TIMESTAMP,
    deleted_at      TIMESTAMPTZ,
    UNIQUE(organization_id, name)
);

CREATE TABLE inventory.equipment_status (
    id              SERIAL      PRIMARY KEY,
    organization_id UUID        NOT NULL REFERENCES users.organizations(id) ON DELETE RESTRICT,
    name            VARCHAR(50) NOT NULL,
    description     TEXT,
    is_operational  BOOLEAN     NOT NULL DEFAULT TRUE,
    created_at      TIMESTAMPTZ NOT NULL DEFAULT CURRENT_TIMESTAMP,
    deleted_at      TIMESTAMPTZ,
    UNIQUE(organization_id, name)
);

CREATE TABLE inventory.equipment (
    id              UUID        PRIMARY KEY DEFAULT gen_random_uuid(),
    organization_id UUID        NOT NULL REFERENCES users.organizations(id) ON DELETE RESTRICT,
    name            VARCHAR(150) NOT NULL,
    serial_number   VARCHAR(100),
    asset_tag       VARCHAR(100),
    type_id         INT         NOT NULL REFERENCES inventory.equipment_types(id) ON DELETE RESTRICT,
    environment_id  INT         REFERENCES inventory.environments(id) ON DELETE SET NULL,
    status_id       INT         NOT NULL REFERENCES inventory.equipment_status(id) ON DELETE RESTRICT,
    brand           VARCHAR(100),
    model           VARCHAR(100),
    purchase_date   DATE,
    warranty_until  DATE,
    metadata        JSONB        NOT NULL DEFAULT '{}',
    notes           TEXT,
    created_at      TIMESTAMPTZ NOT NULL DEFAULT CURRENT_TIMESTAMP,
    updated_at      TIMESTAMPTZ,
    deleted_at      TIMESTAMPTZ,
    UNIQUE(organization_id, serial_number),
    UNIQUE(organization_id, asset_tag)
);

CREATE TABLE inventory.equipment_assignments (
    id              SERIAL      PRIMARY KEY,
    equipment_id    UUID        NOT NULL REFERENCES inventory.equipment(id) ON DELETE RESTRICT,
    user_id         UUID        NOT NULL REFERENCES users.users(id) ON DELETE RESTRICT,
    assigned_by     UUID        REFERENCES users.users(id) ON DELETE SET NULL,
    assigned_at     TIMESTAMPTZ NOT NULL DEFAULT CURRENT_TIMESTAMP,
    returned_at     TIMESTAMPTZ,
    notes           TEXT,
    CONSTRAINT chk_assignment_dates CHECK (
        returned_at IS NULL OR returned_at >= assigned_at
    )
);

CREATE TABLE inventory.maintenance_types (
    id          SERIAL      PRIMARY KEY,
    name        VARCHAR(100) NOT NULL UNIQUE,
    created_at  TIMESTAMPTZ NOT NULL DEFAULT CURRENT_TIMESTAMP,
    deleted_at  TIMESTAMPTZ                                   -- ✅ Soft delete añadido
);

CREATE TABLE inventory.maintenance_history (
    id                  SERIAL      PRIMARY KEY,
    equipment_id        UUID        NOT NULL REFERENCES inventory.equipment(id) ON DELETE RESTRICT,
    maintenance_type_id INT         NOT NULL REFERENCES inventory.maintenance_types(id) ON DELETE RESTRICT,
    performed_by        UUID        NOT NULL REFERENCES users.users(id) ON DELETE RESTRICT,
    ticket_id           UUID,
    description         TEXT        NOT NULL,
    cost                NUMERIC(12,2),
    performed_at        TIMESTAMPTZ NOT NULL DEFAULT CURRENT_TIMESTAMP,
    next_maintenance_at TIMESTAMPTZ,
    created_at          TIMESTAMPTZ NOT NULL DEFAULT CURRENT_TIMESTAMP,
    CONSTRAINT chk_maintenance_cost CHECK (cost IS NULL OR cost >= 0)
);

-- Triggers inventory
CREATE TRIGGER trg_inventory_environments_updated_at
    BEFORE UPDATE ON inventory.environments
    FOR EACH ROW EXECUTE FUNCTION audit.set_updated_at();

CREATE TRIGGER trg_inventory_equipment_updated_at
    BEFORE UPDATE ON inventory.equipment
    FOR EACH ROW EXECUTE FUNCTION audit.set_updated_at();

-- Índices inventory
CREATE INDEX idx_equipment_org         ON inventory.equipment(organization_id) WHERE deleted_at IS NULL;
CREATE INDEX idx_equipment_serial      ON inventory.equipment(organization_id, serial_number) WHERE deleted_at IS NULL;
CREATE INDEX idx_equipment_asset_tag   ON inventory.equipment(organization_id, asset_tag) WHERE deleted_at IS NULL;
CREATE INDEX idx_equipment_environment ON inventory.equipment(environment_id) WHERE deleted_at IS NULL;
CREATE INDEX idx_equipment_type        ON inventory.equipment(type_id);
CREATE INDEX idx_equipment_status      ON inventory.equipment(status_id);
CREATE INDEX idx_equipment_name_trgm   ON inventory.equipment USING gin(name gin_trgm_ops);
CREATE INDEX idx_environment_block     ON inventory.environments(block_id);
CREATE INDEX idx_assignments_equipment ON inventory.equipment_assignments(equipment_id);
CREATE INDEX idx_assignments_user      ON inventory.equipment_assignments(user_id);
CREATE INDEX idx_assignments_active    ON inventory.equipment_assignments(equipment_id) WHERE returned_at IS NULL;
CREATE INDEX idx_maintenance_equipment ON inventory.maintenance_history(equipment_id);
CREATE INDEX idx_maintenance_date      ON inventory.maintenance_history(performed_at DESC);

-- Seed
INSERT INTO inventory.maintenance_types (name) VALUES
    ('Preventivo'), ('Correctivo'), ('Predictivo'), ('Actualización');


-- ============================================================================
-- 8. SCHEMA: tickets (core con SLA mejorado)
-- ============================================================================

CREATE TABLE tickets.ticket_status (
    id              SERIAL      PRIMARY KEY,
    organization_id UUID        NOT NULL REFERENCES users.organizations(id) ON DELETE RESTRICT,
    name            VARCHAR(50) NOT NULL,
    description     TEXT,
    is_terminal     BOOLEAN     NOT NULL DEFAULT FALSE,
    sort_order      SMALLINT    NOT NULL DEFAULT 0,
    created_at      TIMESTAMPTZ NOT NULL DEFAULT CURRENT_TIMESTAMP,
    deleted_at      TIMESTAMPTZ,
    UNIQUE(organization_id, name)
);

CREATE TABLE tickets.ticket_priority (
    id              SERIAL      PRIMARY KEY,
    organization_id UUID        NOT NULL REFERENCES users.organizations(id) ON DELETE RESTRICT,
    name            VARCHAR(50) NOT NULL,
    level           SMALLINT    NOT NULL,
    color           VARCHAR(7)  NOT NULL DEFAULT '#6c757d',
    created_at      TIMESTAMPTZ NOT NULL DEFAULT CURRENT_TIMESTAMP,
    deleted_at      TIMESTAMPTZ,
    UNIQUE(organization_id, name),
    UNIQUE(organization_id, level)
);

CREATE TABLE tickets.ticket_categories (
    id              SERIAL      PRIMARY KEY,
    organization_id UUID        NOT NULL REFERENCES users.organizations(id) ON DELETE RESTRICT,
    name            VARCHAR(100) NOT NULL,
    description     TEXT,
    parent_id       INT         REFERENCES tickets.ticket_categories(id) ON DELETE SET NULL,
    is_active       BOOLEAN     NOT NULL DEFAULT TRUE,
    created_at      TIMESTAMPTZ NOT NULL DEFAULT CURRENT_TIMESTAMP,
    deleted_at      TIMESTAMPTZ,
    UNIQUE(organization_id, name)
);

CREATE TABLE tickets.sla_policies (
    id                      SERIAL      PRIMARY KEY,
    organization_id         UUID        NOT NULL REFERENCES users.organizations(id) ON DELETE RESTRICT,
    priority_id             INT         NOT NULL REFERENCES tickets.ticket_priority(id) ON DELETE CASCADE,
    name                    VARCHAR(100) NOT NULL,
    response_time_hours     INT         NOT NULL CHECK (response_time_hours > 0),
    resolution_time_hours   INT         NOT NULL CHECK (resolution_time_hours > 0),
    escalation_after_hours  INT,
    created_at              TIMESTAMPTZ NOT NULL DEFAULT CURRENT_TIMESTAMP,
    updated_at              TIMESTAMPTZ,
    deleted_at              TIMESTAMPTZ,
    UNIQUE(organization_id, priority_id),
    CONSTRAINT chk_sla_times CHECK (resolution_time_hours >= response_time_hours)
);

CREATE TABLE tickets.tags (
    id              SERIAL      PRIMARY KEY,
    organization_id UUID        NOT NULL REFERENCES users.organizations(id) ON DELETE RESTRICT,
    name            VARCHAR(50) NOT NULL,
    color           VARCHAR(7)  NOT NULL DEFAULT '#6c757d',
    created_at      TIMESTAMPTZ NOT NULL DEFAULT CURRENT_TIMESTAMP,
    deleted_at      TIMESTAMPTZ,
    UNIQUE(organization_id, name)
);

-- ✅ NUEVO: Trigger automático para crear configuración por defecto al crear organización
CREATE OR REPLACE FUNCTION users.create_default_ticket_config()
RETURNS TRIGGER AS $$
BEGIN
    -- Estados por defecto
    INSERT INTO tickets.ticket_status (organization_id, name, description, is_terminal, sort_order) VALUES
        (NEW.id, 'abierto', 'Ticket recién creado, sin atender', FALSE, 1),
        (NEW.id, 'en_proceso', 'Ticket asignado y siendo atendido', FALSE, 2),
        (NEW.id, 'en_espera', 'Esperando respuesta del solicitante', FALSE, 3),
        (NEW.id, 'resuelto', 'Solución aplicada, pendiente confirmación', FALSE, 4),
        (NEW.id, 'cerrado', 'Ticket finalizado y confirmado', TRUE, 5),
        (NEW.id, 'cancelado', 'Ticket anulado', TRUE, 6);
    
    -- Prioridades por defecto
    INSERT INTO tickets.ticket_priority (organization_id, name, level, color) VALUES
        (NEW.id, 'baja', 1, '#28a745'),
        (NEW.id, 'media', 2, '#ffc107'),
        (NEW.id, 'alta', 3, '#fd7e14'),
        (NEW.id, 'urgente', 4, '#dc3545');
    
    -- SLA Policies por defecto
    INSERT INTO tickets.sla_policies (organization_id, priority_id, name, response_time_hours, resolution_time_hours)
    SELECT NEW.id, tp.id, 'SLA ' || tp.name,
        CASE tp.name
            WHEN 'baja' THEN 24
            WHEN 'media' THEN 8
            WHEN 'alta' THEN 4
            WHEN 'urgente' THEN 1
        END,
        CASE tp.name
            WHEN 'baja' THEN 72
            WHEN 'media' THEN 24
            WHEN 'alta' THEN 8
            WHEN 'urgente' THEN 4
        END
    FROM tickets.ticket_priority tp
    WHERE tp.organization_id = NEW.id;
    
    RETURN NEW;
END;
$$ LANGUAGE plpgsql SECURITY DEFINER;

-- ✅ NUEVO: Trigger para crear configuración por defecto al crear organización
CREATE TRIGGER trg_create_default_ticket_config
    AFTER INSERT ON users.organizations
    FOR EACH ROW
    EXECUTE FUNCTION users.create_default_ticket_config();

-- Tabla principal de tickets — particionada por rango de fecha
CREATE TABLE tickets.tickets (
    id                      UUID        NOT NULL DEFAULT gen_random_uuid(),
    organization_id         UUID        NOT NULL REFERENCES users.organizations(id) ON DELETE RESTRICT,
    ticket_number           BIGINT      NOT NULL,
    title                   VARCHAR(255) NOT NULL,
    description             TEXT        NOT NULL,
    created_by              UUID        NOT NULL REFERENCES users.users(id) ON DELETE RESTRICT,
    assigned_to             UUID        REFERENCES users.users(id) ON DELETE SET NULL,
    equipment_id            UUID        REFERENCES inventory.equipment(id) ON DELETE SET NULL,
    category_id             INT         REFERENCES tickets.ticket_categories(id) ON DELETE SET NULL,
    priority_id             INT         NOT NULL REFERENCES tickets.ticket_priority(id) ON DELETE RESTRICT,
    status_id               INT         NOT NULL REFERENCES tickets.ticket_status(id) ON DELETE RESTRICT,
    sla_response_due_at     TIMESTAMPTZ,
    sla_resolution_due_at   TIMESTAMPTZ,
    sla_breached            BOOLEAN     NOT NULL DEFAULT FALSE,
    first_response_at       TIMESTAMPTZ,
    resolved_at             TIMESTAMPTZ,
    closed_at               TIMESTAMPTZ,
    satisfaction_score      SMALLINT,
    satisfaction_comment    TEXT,
    metadata                JSONB        NOT NULL DEFAULT '{}',
    deleted_at              TIMESTAMPTZ,
    created_at              TIMESTAMPTZ NOT NULL DEFAULT CURRENT_TIMESTAMP,
    updated_at              TIMESTAMPTZ,
    PRIMARY KEY (id, created_at),
    CONSTRAINT chk_ticket_dates CHECK (
        (resolved_at IS NULL OR resolved_at >= created_at) AND
        (closed_at   IS NULL OR closed_at   >= created_at)
    ),
    CONSTRAINT chk_satisfaction_score CHECK (satisfaction_score BETWEEN 1 AND 5), -- ✅ Añadido
    CONSTRAINT chk_sla_breached CHECK (
        (sla_breached = TRUE AND sla_resolution_due_at IS NOT NULL AND resolved_at IS NULL) OR
        (sla_breached = FALSE)
    )
) PARTITION BY RANGE (created_at);

CREATE TABLE tickets.ticket_comments (
    id          UUID        NOT NULL DEFAULT gen_random_uuid(),
    ticket_id   UUID        NOT NULL,
    user_id     UUID        NOT NULL REFERENCES users.users(id) ON DELETE RESTRICT,
    comment     TEXT        NOT NULL,
    is_internal BOOLEAN     NOT NULL DEFAULT FALSE,
    created_at  TIMESTAMPTZ NOT NULL DEFAULT CURRENT_TIMESTAMP,
    updated_at  TIMESTAMPTZ,
    deleted_at  TIMESTAMPTZ,
    PRIMARY KEY (id, created_at),
    CONSTRAINT chk_comment_not_empty CHECK (length(trim(comment)) > 0)
) PARTITION BY RANGE (created_at);

CREATE TABLE tickets.ticket_history (
    id          BIGSERIAL   NOT NULL,
    ticket_id   UUID        NOT NULL,
    changed_by  UUID,
    field_name  VARCHAR(50) NOT NULL,
    old_value   TEXT,
    new_value   TEXT,
    old_id      TEXT,
    new_id      TEXT,
    changed_at  TIMESTAMPTZ NOT NULL DEFAULT CURRENT_TIMESTAMP,
    PRIMARY KEY (id, changed_at)
) PARTITION BY RANGE (changed_at);

CREATE TABLE tickets.ticket_tags (
    ticket_id   UUID NOT NULL,
    tag_id      INT  NOT NULL REFERENCES tickets.tags(id) ON DELETE CASCADE,
    created_at  TIMESTAMPTZ NOT NULL DEFAULT CURRENT_TIMESTAMP,
    PRIMARY KEY (ticket_id, tag_id)
);

-- ============================================================================
-- 8.1 PARTICIONES INICIALES (12 meses adelante + histórico)
-- ============================================================================

DO $$
DECLARE
    start_date DATE := DATE_TRUNC('month', CURRENT_DATE - INTERVAL '3 months');
    end_date   DATE := DATE_TRUNC('month', CURRENT_DATE + INTERVAL '13 months');
    cur_date   DATE := start_date;
    next_date  DATE;
    suffix     TEXT;
BEGIN
    WHILE cur_date < end_date LOOP
        next_date := cur_date + INTERVAL '1 month';
        suffix    := TO_CHAR(cur_date, 'YYYY_MM');

        EXECUTE FORMAT(
            'CREATE TABLE IF NOT EXISTS tickets.tickets_%s
             PARTITION OF tickets.tickets
             FOR VALUES FROM (%L) TO (%L)',
            suffix, cur_date, next_date
        );
        EXECUTE FORMAT(
            'CREATE TABLE IF NOT EXISTS tickets.ticket_comments_%s
             PARTITION OF tickets.ticket_comments
             FOR VALUES FROM (%L) TO (%L)',
            suffix, cur_date, next_date
        );
        EXECUTE FORMAT(
            'CREATE TABLE IF NOT EXISTS tickets.ticket_history_%s
             PARTITION OF tickets.ticket_history
             FOR VALUES FROM (%L) TO (%L)',
            suffix, cur_date, next_date
        );

        cur_date := next_date;
    END LOOP;
END $$;

-- ============================================================================
-- 8.2 TRIGGERS DE TICKETS (orden documentado)
-- ============================================================================

-- TRIGGER 1: Calcular SLA al crear ticket
CREATE OR REPLACE FUNCTION tickets.calculate_sla()
RETURNS TRIGGER AS $$
DECLARE
    v_resp_hours INT;
    v_resol_hours INT;
BEGIN
    SELECT response_time_hours, resolution_time_hours
    INTO   v_resp_hours, v_resol_hours
    FROM   tickets.sla_policies
    WHERE  organization_id = NEW.organization_id
    AND    priority_id     = NEW.priority_id
    AND    deleted_at IS NULL;

    IF FOUND THEN
        NEW.sla_response_due_at   := NEW.created_at + (v_resp_hours  || ' hours')::INTERVAL;
        NEW.sla_resolution_due_at := NEW.created_at + (v_resol_hours || ' hours')::INTERVAL;
    END IF;

    RETURN NEW;
END;
$$ LANGUAGE plpgsql;

CREATE TRIGGER trg_ticket_calculate_sla
    BEFORE INSERT ON tickets.tickets
    FOR EACH ROW EXECUTE FUNCTION tickets.calculate_sla();

-- TRIGGER 2: Recalcular SLA al cambiar prioridad (BEFORE)
CREATE OR REPLACE FUNCTION tickets.recalculate_sla_on_priority_change()
RETURNS TRIGGER AS $$
DECLARE
    v_resp_hours  INT;
    v_resol_hours INT;
BEGIN
    IF NEW.priority_id IS DISTINCT FROM OLD.priority_id THEN
        SELECT response_time_hours, resolution_time_hours
        INTO   v_resp_hours, v_resol_hours
        FROM   tickets.sla_policies
        WHERE  organization_id = NEW.organization_id
        AND    priority_id     = NEW.priority_id
        AND    deleted_at IS NULL;

        IF FOUND THEN
            NEW.sla_response_due_at   := CURRENT_TIMESTAMP + (v_resp_hours  || ' hours')::INTERVAL;
            NEW.sla_resolution_due_at := CURRENT_TIMESTAMP + (v_resol_hours || ' hours')::INTERVAL;
            NEW.sla_breached          := FALSE;
        END IF;
    END IF;

    IF NEW.sla_resolution_due_at IS NOT NULL
       AND CURRENT_TIMESTAMP > NEW.sla_resolution_due_at
       AND NEW.resolved_at IS NULL THEN
        NEW.sla_breached := TRUE;
    END IF;

    RETURN NEW;
END;
$$ LANGUAGE plpgsql;

CREATE TRIGGER trg_ticket_sla_on_update
    BEFORE UPDATE ON tickets.tickets
    FOR EACH ROW EXECUTE FUNCTION tickets.recalculate_sla_on_priority_change();

-- TRIGGER 3: Timestamps automáticos y updated_at (BEFORE)
-- ORDEN: Este trigger DEBE ejecutarse ANTES que trg_ticket_log_changes
-- para que resolved_at/closed_at estén actualizados en el historial
CREATE OR REPLACE FUNCTION tickets.auto_timestamps()
RETURNS TRIGGER AS $$
BEGIN
    NEW.updated_at := CURRENT_TIMESTAMP;

    IF NEW.status_id IS DISTINCT FROM OLD.status_id THEN
        IF EXISTS (SELECT 1 FROM tickets.ticket_status WHERE id = NEW.status_id AND name = 'resuelto') THEN
            NEW.resolved_at := COALESCE(NEW.resolved_at, CURRENT_TIMESTAMP);
        END IF;

        IF EXISTS (SELECT 1 FROM tickets.ticket_status WHERE id = NEW.status_id AND is_terminal = TRUE) THEN
            NEW.closed_at := COALESCE(NEW.closed_at, CURRENT_TIMESTAMP);
        END IF;
    END IF;

    RETURN NEW;
END;
$$ LANGUAGE plpgsql;

CREATE TRIGGER trg_ticket_auto_timestamps
    BEFORE UPDATE ON tickets.tickets
    FOR EACH ROW EXECUTE FUNCTION tickets.auto_timestamps();

-- TRIGGER 4: Historial campo a campo (AFTER)
-- NOTA: Se ejecuta DESPUÉS de trg_ticket_auto_timestamps para tener timestamps correctos
CREATE OR REPLACE FUNCTION tickets.log_ticket_changes()
RETURNS TRIGGER AS $$
DECLARE
    v_actor       UUID;
    v_old_label   TEXT;
    v_new_label   TEXT;
BEGIN
    v_actor := app.get_current_user_id();

    IF NEW.status_id IS DISTINCT FROM OLD.status_id THEN
        SELECT name INTO v_old_label FROM tickets.ticket_status WHERE id = OLD.status_id;
        SELECT name INTO v_new_label FROM tickets.ticket_status WHERE id = NEW.status_id;
        INSERT INTO tickets.ticket_history(ticket_id, changed_by, field_name, old_value, new_value, old_id, new_id)
        VALUES(NEW.id, v_actor, 'status', v_old_label, v_new_label, OLD.status_id::TEXT, NEW.status_id::TEXT);
    END IF;

    IF NEW.priority_id IS DISTINCT FROM OLD.priority_id THEN
        SELECT name INTO v_old_label FROM tickets.ticket_priority WHERE id = OLD.priority_id;
        SELECT name INTO v_new_label FROM tickets.ticket_priority WHERE id = NEW.priority_id;
        INSERT INTO tickets.ticket_history(ticket_id, changed_by, field_name, old_value, new_value, old_id, new_id)
        VALUES(NEW.id, v_actor, 'priority', v_old_label, v_new_label, OLD.priority_id::TEXT, NEW.priority_id::TEXT);
    END IF;

    IF NEW.assigned_to IS DISTINCT FROM OLD.assigned_to THEN
        SELECT first_name || ' ' || last_name INTO v_old_label FROM users.users WHERE id = OLD.assigned_to;
        SELECT first_name || ' ' || last_name INTO v_new_label FROM users.users WHERE id = NEW.assigned_to;
        INSERT INTO tickets.ticket_history(ticket_id, changed_by, field_name, old_value, new_value, old_id, new_id)
        VALUES(NEW.id, v_actor, 'assigned_to', v_old_label, v_new_label, OLD.assigned_to::TEXT, NEW.assigned_to::TEXT);
    END IF;

    IF NEW.category_id IS DISTINCT FROM OLD.category_id THEN
        SELECT name INTO v_old_label FROM tickets.ticket_categories WHERE id = OLD.category_id;
        SELECT name INTO v_new_label FROM tickets.ticket_categories WHERE id = NEW.category_id;
        INSERT INTO tickets.ticket_history(ticket_id, changed_by, field_name, old_value, new_value, old_id, new_id)
        VALUES(NEW.id, v_actor, 'category', v_old_label, v_new_label, OLD.category_id::TEXT, NEW.category_id::TEXT);
    END IF;

    RETURN NEW;
END;
$$ LANGUAGE plpgsql;

CREATE TRIGGER trg_ticket_log_changes
    AFTER UPDATE ON tickets.tickets
    FOR EACH ROW EXECUTE FUNCTION tickets.log_ticket_changes();

-- Trigger updated_at para comentarios
CREATE TRIGGER trg_ticket_comments_updated_at
    BEFORE UPDATE ON tickets.ticket_comments
    FOR EACH ROW EXECUTE FUNCTION audit.set_updated_at();

-- Índices tickets
CREATE INDEX idx_tickets_org_status    ON tickets.tickets(organization_id, status_id)   WHERE deleted_at IS NULL;
CREATE INDEX idx_tickets_org_priority  ON tickets.tickets(organization_id, priority_id) WHERE deleted_at IS NULL;
CREATE INDEX idx_tickets_org_assigned  ON tickets.tickets(organization_id, assigned_to) WHERE deleted_at IS NULL;
CREATE INDEX idx_tickets_org_ticket_number ON tickets.tickets(organization_id, ticket_number)
                                       WHERE deleted_at IS NULL;
CREATE INDEX idx_tickets_created_by    ON tickets.tickets(created_by);
CREATE INDEX idx_tickets_equipment     ON tickets.tickets(equipment_id);
CREATE INDEX idx_tickets_sla_due       ON tickets.tickets(sla_resolution_due_at)
                                       WHERE resolved_at IS NULL AND deleted_at IS NULL;
CREATE INDEX idx_tickets_sla_breach    ON tickets.tickets(organization_id, sla_breached)
                                       WHERE sla_breached = TRUE AND deleted_at IS NULL;
CREATE INDEX idx_tickets_created_at    ON tickets.tickets(created_at DESC);
CREATE INDEX idx_tickets_title_trgm    ON tickets.tickets USING gin(title gin_trgm_ops);
CREATE INDEX idx_ticket_comments_ticket ON tickets.ticket_comments(ticket_id, created_at DESC)
                                        WHERE deleted_at IS NULL;
CREATE INDEX idx_ticket_history_ticket  ON tickets.ticket_history(ticket_id, changed_at DESC);

-- Seed ticket_status por organización (ejecutar después de crear organizaciones)
-- Los seeds se deben ejecutar por cada organización creada


-- ============================================================================
-- 9. SCHEMA: files
-- ============================================================================

CREATE TABLE files.owner_types (
    id   SERIAL      PRIMARY KEY,
    name VARCHAR(50) NOT NULL UNIQUE,
    deleted_at TIMESTAMPTZ                                   -- ✅ Soft delete añadido
);

INSERT INTO files.owner_types (name) VALUES ('ticket'), ('comment'), ('maintenance'), ('user');

CREATE TABLE files.files (
    id               UUID        PRIMARY KEY DEFAULT gen_random_uuid(),
    organization_id  UUID        NOT NULL REFERENCES users.organizations(id) ON DELETE RESTRICT,
    owner_type_id    INT         NOT NULL REFERENCES files.owner_types(id) ON DELETE RESTRICT,
    owner_id         UUID        NOT NULL,
    uploaded_by      UUID        NOT NULL REFERENCES users.users(id) ON DELETE RESTRICT,
    file_name        VARCHAR(255) NOT NULL,
    original_name    VARCHAR(255) NOT NULL,
    mime_type        VARCHAR(100),
    file_size        INT         NOT NULL CHECK (file_size > 0),
    storage_provider VARCHAR(50) NOT NULL DEFAULT 's3',
    storage_path     TEXT        NOT NULL,
    checksum         VARCHAR(64),
    is_public        BOOLEAN     NOT NULL DEFAULT FALSE,
    deleted_at       TIMESTAMPTZ,
    created_at       TIMESTAMPTZ NOT NULL DEFAULT CURRENT_TIMESTAMP,
    CONSTRAINT chk_checksum CHECK (checksum IS NULL OR length(checksum) = 64)
);

CREATE INDEX idx_files_owner       ON files.files(owner_type_id, owner_id) WHERE deleted_at IS NULL;
CREATE INDEX idx_files_uploaded_by ON files.files(uploaded_by);
CREATE INDEX idx_files_org         ON files.files(organization_id);


-- ============================================================================
-- 10. SCHEMA: notifications (con soft delete universal)
-- ============================================================================

CREATE TABLE notifications.notification_types (
    id          SERIAL      PRIMARY KEY,
    name        VARCHAR(100) NOT NULL UNIQUE,
    template    TEXT,
    created_at  TIMESTAMPTZ NOT NULL DEFAULT CURRENT_TIMESTAMP,
    deleted_at  TIMESTAMPTZ                                   -- ✅ Soft delete añadido
);

CREATE TABLE notifications.notifications (
    id          UUID        NOT NULL DEFAULT gen_random_uuid(),
    user_id     UUID        NOT NULL REFERENCES users.users(id) ON DELETE CASCADE,
    type_id     INT         NOT NULL REFERENCES notifications.notification_types(id) ON DELETE RESTRICT,
    title       VARCHAR(255) NOT NULL,
    message     TEXT        NOT NULL,
    metadata    JSONB        NOT NULL DEFAULT '{}',
    channel     VARCHAR(20) NOT NULL DEFAULT 'in_app'
                    CHECK (channel IN ('in_app','email','push','whatsapp','sms')),
    is_read     BOOLEAN     NOT NULL DEFAULT FALSE,
    read_at     TIMESTAMPTZ,
    sent_at     TIMESTAMPTZ,
    delivered_at TIMESTAMPTZ,
    created_at  TIMESTAMPTZ NOT NULL DEFAULT CURRENT_TIMESTAMP,
    PRIMARY KEY (id, created_at),
    CONSTRAINT chk_read_at CHECK (read_at IS NULL OR is_read = TRUE)
) PARTITION BY RANGE (created_at);

-- Particiones de notificaciones
DO $$
DECLARE
    cur_date  DATE := DATE_TRUNC('month', CURRENT_DATE - INTERVAL '1 month');
    end_date  DATE := DATE_TRUNC('month', CURRENT_DATE + INTERVAL '7 months');
    next_date DATE;
    suffix    TEXT;
BEGIN
    WHILE cur_date < end_date LOOP
        next_date := cur_date + INTERVAL '1 month';
        suffix    := TO_CHAR(cur_date, 'YYYY_MM');
        EXECUTE FORMAT(
            'CREATE TABLE IF NOT EXISTS notifications.notifications_%s
             PARTITION OF notifications.notifications
             FOR VALUES FROM (%L) TO (%L)',
            suffix, cur_date, next_date
        );
        cur_date := next_date;
    END LOOP;
END $$;

-- Triggers de notificaciones
CREATE OR REPLACE FUNCTION notifications.notify_ticket_assignment()
RETURNS TRIGGER AS $$
DECLARE
    v_type_id INT;
BEGIN
    IF NEW.assigned_to IS NOT NULL
       AND NEW.assigned_to IS DISTINCT FROM OLD.assigned_to THEN
 
        SELECT id INTO v_type_id
        FROM   notifications.notification_types
        WHERE  name = 'ticket_assigned'
        AND    deleted_at IS NULL;
 
        INSERT INTO notifications.notifications(
            user_id, type_id, title, message, metadata, channel
        ) VALUES (
            NEW.assigned_to,
            v_type_id,
            'Ticket asignado: ' || LEFT(NEW.title, 60),
            'Se te ha asignado el ticket #' || NEW.ticket_number || ': ' || NEW.title,
            jsonb_build_object(
                'ticket_id',     NEW.id,
                'ticket_number', NEW.ticket_number,
                'priority_id',   NEW.priority_id,
                'assigned_at',   CURRENT_TIMESTAMP
            ),
            'in_app'
        );
 
        PERFORM pg_notify(
            'ticket_assignments',
            jsonb_build_object(
                'ticket_id',      NEW.id,
                'user_id',        NEW.assigned_to,
                'organization_id',NEW.organization_id
            )::TEXT
        );
    END IF;
    RETURN NEW;
END;
$$ LANGUAGE plpgsql;

CREATE TRIGGER trg_ticket_assignment_notification
    AFTER UPDATE ON tickets.tickets
    FOR EACH ROW EXECUTE FUNCTION notifications.notify_ticket_assignment();

CREATE OR REPLACE FUNCTION notifications.notify_ticket_closed()
RETURNS TRIGGER AS $$
DECLARE
    v_type_id INT;
    v_is_terminal BOOLEAN;
BEGIN
    IF NEW.status_id IS DISTINCT FROM OLD.status_id THEN
        SELECT is_terminal INTO v_is_terminal
        FROM   tickets.ticket_status
        WHERE  id = NEW.status_id;
 
        IF v_is_terminal = TRUE THEN
            SELECT id INTO v_type_id
            FROM   notifications.notification_types
            WHERE  name = 'ticket_closed'
            AND    deleted_at IS NULL;
 
            INSERT INTO notifications.notifications(
                user_id, type_id, title, message, metadata, channel
            ) VALUES (
                NEW.created_by,
                v_type_id,
                'Tu ticket ha sido cerrado',
                'El ticket "' || LEFT(NEW.title, 80) || '" (#' || NEW.ticket_number || ') ha sido cerrado.',
                jsonb_build_object('ticket_id', NEW.id, 'ticket_number', NEW.ticket_number),
                'in_app'
            );
        END IF;
    END IF;
    RETURN NEW;
END;
$$ LANGUAGE plpgsql;

CREATE TRIGGER trg_ticket_closed_notification
    AFTER UPDATE ON tickets.tickets
    FOR EACH ROW EXECUTE FUNCTION notifications.notify_ticket_closed();

-- Índices notifications
CREATE INDEX idx_notifications_user_unread ON notifications.notifications(user_id, is_read)
                                           WHERE is_read = FALSE;
CREATE INDEX idx_notifications_created_at  ON notifications.notifications(created_at DESC);

