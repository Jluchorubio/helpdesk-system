-- ============================================================================
-- HELPDESK DATABASE — VERSIÓN DEFINITIVA MEJORADA 4.1
-- ============================================================================
-- Basada en: Versión Final Definitiva + Mejoras de Versión Híbrida
-- ============================================================================
-- MEJORAS INCORPORADAS:
-- 1. Soft delete universal en TODAS las tablas
-- 2. Check constraints exhaustivas
-- 3. Vistas materializadas con métricas enriquecidas
-- 4. Secuencias para ticket_number por organización
-- 5. Documentación de orden de triggers
-- 6. Funciones de mantenimiento automático
-- 7. ✅ CORRECCIÓN: Función app.get_current_role() añadida
-- 8. ✅ CORRECCIÓN: Políticas DENY explícitas para escritura
-- 9. ✅ CORRECCIÓN: Trigger automático para config por organización
-- ============================================================================

-- ============================================================================
-- 1. EXTENSIONES
-- ============================================================================

CREATE EXTENSION IF NOT EXISTS pgcrypto;
CREATE EXTENSION IF NOT EXISTS pg_trgm;      -- búsqueda full-text
CREATE EXTENSION IF NOT EXISTS btree_gist;   -- índices de rango para fechas
-- pg_partman ya no es necesario: particionamiento manual explícito


-- ============================================================================
-- 2. SCHEMAS
-- ============================================================================

CREATE SCHEMA IF NOT EXISTS app;
CREATE SCHEMA IF NOT EXISTS users;
CREATE SCHEMA IF NOT EXISTS inventory;
CREATE SCHEMA IF NOT EXISTS tickets;
CREATE SCHEMA IF NOT EXISTS files;
CREATE SCHEMA IF NOT EXISTS notifications;
CREATE SCHEMA IF NOT EXISTS audit;
CREATE SCHEMA IF NOT EXISTS reports;
CREATE SCHEMA IF NOT EXISTS maintenance;


-- ============================================================================
-- 3. CONFIGURACIÓN DE SESIÓN PARA RLS Y CONTEXTO DE APP
-- ============================================================================

-- Variables de sesión (seteadas por la aplicación)
--   SET LOCAL app.current_user_id         = '<uuid>';
--   SET LOCAL app.current_organization_id = '<uuid>';
--   SET LOCAL app.user_role               = 'admin';


-- ============================================================================
-- 4. FUNCIONES GLOBALES DE CONTEXTO
-- ============================================================================

CREATE OR REPLACE FUNCTION app.get_current_user_id()
RETURNS UUID AS $$
DECLARE
    v_user_id UUID;
BEGIN
    -- Prefer explicit session variable (backend)
    BEGIN
        v_user_id := current_setting('app.current_user_id', true)::UUID;
    EXCEPTION WHEN OTHERS THEN
        v_user_id := NULL;
    END;

    IF v_user_id IS NOT NULL THEN
        RETURN v_user_id;
    END IF;

    -- Map Supabase auth.uid() to internal users.users.id (dynamic to avoid dependency order)
    EXECUTE '
        SELECT u.id
        FROM users.users u
        WHERE u.auth_id = auth.uid()
          AND u.deleted_at IS NULL
        LIMIT 1
    '
    INTO v_user_id;

    RETURN v_user_id;
END;
$$ LANGUAGE plpgsql STABLE SECURITY DEFINER SET search_path = public, auth, users, app;

CREATE OR REPLACE FUNCTION app.get_current_organization_id()
RETURNS UUID AS $$
DECLARE
    v_org_id UUID;
BEGIN
    BEGIN
        v_org_id := current_setting('app.current_organization_id', true)::UUID;
    EXCEPTION WHEN OTHERS THEN
        v_org_id := NULL;
    END;

    IF v_org_id IS NOT NULL THEN
        RETURN v_org_id;
    END IF;

    EXECUTE '
        SELECT u.organization_id
        FROM users.users u
        WHERE u.id = $1
          AND u.deleted_at IS NULL
        LIMIT 1
    '
    INTO v_org_id
    USING app.get_current_user_id();

    RETURN v_org_id;
END;
$$ LANGUAGE plpgsql STABLE SECURITY DEFINER SET search_path = public, auth, users, app;

CREATE OR REPLACE FUNCTION app.get_current_role()
RETURNS TEXT AS $$
DECLARE
    v_role TEXT;
BEGIN
    -- Prioridad 1: Variable de sesión (backend)
    BEGIN
        v_role := current_setting('app.user_role', true);
    EXCEPTION WHEN OTHERS THEN
        v_role := NULL;
    END;

    IF v_role IS NOT NULL THEN
        RETURN v_role;
    END IF;

    -- Prioridad 2: De la base de datos (frontend con Supabase)
    EXECUTE '
        SELECT r.name
        FROM users.users u
        JOIN users.roles r ON r.id = u.role_id
        WHERE u.id = $1
          AND u.deleted_at IS NULL
        LIMIT 1
    '
    INTO v_role
    USING app.get_current_user_id();

    RETURN v_role;
END;
$$ LANGUAGE plpgsql STABLE SECURITY DEFINER SET search_path = public, auth, users, app;

CREATE OR REPLACE FUNCTION audit.set_updated_at()
RETURNS TRIGGER AS $$
BEGIN
    NEW.updated_at = CURRENT_TIMESTAMP;
    RETURN NEW;
END;
$$ LANGUAGE plpgsql;


-- ============================================================================
-- 5. AUTH
-- Se usa Supabase Auth (schema auth.users). No se crean tablas propias aquí.
-- ============================================================================


-- ============================================================================
-- 6. SCHEMA: users (con secuencias por organización)
-- ============================================================================

CREATE TABLE users.organizations (
    id          UUID        PRIMARY KEY DEFAULT gen_random_uuid(),
    name        VARCHAR(255) NOT NULL,
    subdomain   VARCHAR(100) UNIQUE,
    settings    JSONB        NOT NULL DEFAULT '{}',
    is_active   BOOLEAN      NOT NULL DEFAULT TRUE,
    ticket_sequence_last BIGINT NOT NULL DEFAULT 0,          -- ✅ Para ticket_number secuencial
    created_at  TIMESTAMPTZ  NOT NULL DEFAULT CURRENT_TIMESTAMP,
    updated_at  TIMESTAMPTZ,
    deleted_at  TIMESTAMPTZ
);

CREATE TABLE users.roles (
    id          SERIAL      PRIMARY KEY,
    name        VARCHAR(50) NOT NULL UNIQUE,
    description TEXT,
    created_at  TIMESTAMPTZ NOT NULL DEFAULT CURRENT_TIMESTAMP,
    deleted_at  TIMESTAMPTZ                                   -- ✅ Soft delete añadido
);

CREATE TABLE users.permissions (
    id          SERIAL       PRIMARY KEY,
    name        VARCHAR(100) NOT NULL UNIQUE,
    description TEXT,
    created_at  TIMESTAMPTZ NOT NULL DEFAULT CURRENT_TIMESTAMP,
    deleted_at  TIMESTAMPTZ                                   -- ✅ Soft delete añadido
);

CREATE TABLE users.role_permissions (
    role_id       INT NOT NULL REFERENCES users.roles(id) ON DELETE CASCADE,
    permission_id INT NOT NULL REFERENCES users.permissions(id) ON DELETE CASCADE,
    PRIMARY KEY (role_id, permission_id)
);

CREATE TABLE users.users (
    id              UUID        PRIMARY KEY DEFAULT gen_random_uuid(),
    auth_id         UUID        NOT NULL UNIQUE REFERENCES auth.users(id) ON DELETE RESTRICT,
    organization_id UUID        NOT NULL REFERENCES users.organizations(id) ON DELETE RESTRICT,
    role_id         INT         NOT NULL REFERENCES users.roles(id) ON DELETE RESTRICT,
    first_name      VARCHAR(100) NOT NULL,
    last_name       VARCHAR(100) NOT NULL,
    avatar_url      TEXT,
    is_active       BOOLEAN     NOT NULL DEFAULT TRUE,
    last_activity_at TIMESTAMPTZ,
    created_at      TIMESTAMPTZ NOT NULL DEFAULT CURRENT_TIMESTAMP,
    updated_at      TIMESTAMPTZ,
    deleted_at      TIMESTAMPTZ,
    UNIQUE(organization_id, auth_id)
);

CREATE TABLE users.user_phones (
    id                  UUID        PRIMARY KEY DEFAULT gen_random_uuid(),
    user_id             UUID        NOT NULL REFERENCES users.users(id) ON DELETE CASCADE,
    country_code        VARCHAR(5)  NOT NULL,
    number              VARCHAR(20) NOT NULL,
    extension           VARCHAR(10),
    is_primary          BOOLEAN     NOT NULL DEFAULT FALSE,
    whatsapp_enabled    BOOLEAN     NOT NULL DEFAULT FALSE,
    verified_at         TIMESTAMPTZ,
    created_at          TIMESTAMPTZ NOT NULL DEFAULT CURRENT_TIMESTAMP,
    updated_at          TIMESTAMPTZ,
    deleted_at          TIMESTAMPTZ,
    UNIQUE(user_id, country_code, number)
);

CREATE TABLE users.user_settings (
    user_id                 UUID        PRIMARY KEY REFERENCES users.users(id) ON DELETE CASCADE,
    language                VARCHAR(10)  NOT NULL DEFAULT 'es',
    theme                   VARCHAR(20)  NOT NULL DEFAULT 'light'
                                CHECK (theme IN ('light', 'dark', 'system')),
    timezone                VARCHAR(60)  NOT NULL DEFAULT 'America/Bogota',
    notifications_enabled   BOOLEAN     NOT NULL DEFAULT TRUE,
    email_notifications     BOOLEAN     NOT NULL DEFAULT TRUE,
    whatsapp_notifications  BOOLEAN     NOT NULL DEFAULT FALSE,
    updated_at              TIMESTAMPTZ
);

-- Función para obtener próximo número de ticket por organización
CREATE OR REPLACE FUNCTION tickets.next_ticket_number(p_organization_id UUID)
RETURNS BIGINT AS $$
DECLARE
    v_next BIGINT;
BEGIN
    UPDATE users.organizations
    SET ticket_sequence_last = ticket_sequence_last + 1
    WHERE id = p_organization_id
    RETURNING ticket_sequence_last INTO v_next;
    
    RETURN v_next;
END;
$$ LANGUAGE plpgsql SECURITY DEFINER;

-- Triggers users
CREATE TRIGGER trg_users_organizations_updated_at
    BEFORE UPDATE ON users.organizations
    FOR EACH ROW EXECUTE FUNCTION audit.set_updated_at();

CREATE TRIGGER trg_users_users_updated_at
    BEFORE UPDATE ON users.users
    FOR EACH ROW EXECUTE FUNCTION audit.set_updated_at();

CREATE TRIGGER trg_users_settings_updated_at
    BEFORE UPDATE ON users.user_settings
    FOR EACH ROW EXECUTE FUNCTION audit.set_updated_at();

CREATE TRIGGER trg_users_phones_updated_at
    BEFORE UPDATE ON users.user_phones
    FOR EACH ROW EXECUTE FUNCTION audit.set_updated_at();

-- Índices users
CREATE INDEX idx_users_org_active    ON users.users(organization_id) WHERE deleted_at IS NULL;
CREATE INDEX idx_users_role          ON users.users(role_id);
CREATE INDEX idx_users_auth_id       ON users.users(auth_id);
CREATE INDEX idx_users_name_trgm     ON users.users USING gin((first_name || ' ' || last_name) gin_trgm_ops);
CREATE INDEX idx_users_phones_primary ON users.user_phones(user_id) WHERE is_primary = TRUE AND deleted_at IS NULL;
CREATE INDEX idx_users_phones_wa      ON users.user_phones(user_id) WHERE whatsapp_enabled = TRUE AND deleted_at IS NULL;

