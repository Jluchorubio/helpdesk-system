INSERT INTO notifications.notification_types (name, template) VALUES
    ('ticket_created',   'Se ha creado el ticket: {{ticket_title}}'),
    ('ticket_assigned',  'Se te ha asignado el ticket: {{ticket_title}}'),
    ('ticket_updated',   'Tu ticket ha sido actualizado: {{ticket_title}}'),
