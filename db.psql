    ('system_alert',     'Alerta del sistema: {{message}}');


-- ============================================================================
-- 11. SCHEMA: audit (con eventos de dominio mejorados)
-- ============================================================================

CREATE TABLE audit.audit_logs (
    id              BIGSERIAL   NOT NULL,
    user_id         UUID,
    organization_id UUID,
    action          VARCHAR(20) NOT NULL CHECK (action IN ('CREATE','UPDATE','DELETE','LOGIN','LOGOUT')),
    entity          VARCHAR(100) NOT NULL,
    entity_id       TEXT,
    old_data        JSONB,
    new_data        JSONB,
    ip_address      INET,
    user_agent      TEXT,
    metadata        JSONB        NOT NULL DEFAULT '{}',
    created_at      TIMESTAMPTZ NOT NULL DEFAULT CURRENT_TIMESTAMP,
    PRIMARY KEY (id, created_at)
) PARTITION BY RANGE (created_at);

CREATE TABLE audit.domain_events (
    id              BIGSERIAL   NOT NULL,
    event_id        UUID        NOT NULL DEFAULT gen_random_uuid(),
    event_name      VARCHAR(100) NOT NULL,
    aggregate_id    UUID        NOT NULL,
    aggregate_type  VARCHAR(50) NOT NULL,
    organization_id UUID,
    payload         JSONB       NOT NULL,
    status          VARCHAR(20) NOT NULL DEFAULT 'pending'
                        CHECK (status IN ('pending','processed','failed','retrying')),
    retry_count     SMALLINT    NOT NULL DEFAULT 0,
    last_error      TEXT,
    created_at      TIMESTAMPTZ NOT NULL DEFAULT CURRENT_TIMESTAMP,
    processed_at    TIMESTAMPTZ,
    PRIMARY KEY (id, created_at)
) PARTITION BY RANGE (created_at);

-- Particiones de audit
DO $$
DECLARE
    cur_date  DATE := DATE_TRUNC('month', CURRENT_DATE - INTERVAL '3 months');
    end_date  DATE := DATE_TRUNC('month', CURRENT_DATE + INTERVAL '13 months');
    next_date DATE;
    suffix    TEXT;
BEGIN
    WHILE cur_date < end_date LOOP
        next_date := cur_date + INTERVAL '1 month';
        suffix    := TO_CHAR(cur_date, 'YYYY_MM');
        EXECUTE FORMAT(
            'CREATE TABLE IF NOT EXISTS audit.audit_logs_%s
             PARTITION OF audit.audit_logs
             FOR VALUES FROM (%L) TO (%L)',
            suffix, cur_date, next_date
        );
        EXECUTE FORMAT(
            'CREATE TABLE IF NOT EXISTS audit.domain_events_%s
             PARTITION OF audit.domain_events
             FOR VALUES FROM (%L) TO (%L)',
            suffix, cur_date, next_date
        );
        cur_date := next_date;
    END LOOP;
END $$;

-- Función de auditoría genérica
CREATE OR REPLACE FUNCTION audit.log_entity_changes()
RETURNS TRIGGER AS $$
DECLARE
    v_action   TEXT;
    v_entity_id TEXT;
    v_old      JSONB;
    v_new      JSONB;
    v_org_id   UUID;
BEGIN
    v_action := CASE TG_OP
        WHEN 'INSERT' THEN 'CREATE'
        WHEN 'UPDATE' THEN 'UPDATE'
        WHEN 'DELETE' THEN 'DELETE'
    END;
 
    IF TG_OP = 'DELETE' THEN
        v_entity_id := OLD.id::TEXT;
        v_old       := to_jsonb(OLD);
        v_new       := NULL;
        v_org_id    := CASE WHEN TG_TABLE_SCHEMA = 'users' THEN NULL
                            ELSE OLD.organization_id END;
    ELSE
        v_entity_id := NEW.id::TEXT;
        v_new       := to_jsonb(NEW);
        v_old       := CASE WHEN TG_OP = 'UPDATE' THEN to_jsonb(OLD) ELSE NULL END;
        v_org_id    := CASE WHEN TG_TABLE_SCHEMA = 'users' THEN NULL
                            ELSE NEW.organization_id END;
    END IF;
 
    INSERT INTO audit.audit_logs(
        user_id, organization_id, action, entity, entity_id, old_data, new_data
    ) VALUES (
        app.get_current_user_id(),
        v_org_id,
        v_action,
        TG_TABLE_SCHEMA || '.' || TG_TABLE_NAME,
        v_entity_id,
        CASE WHEN v_old IS NOT NULL
             THEN v_old - 'password_hash' - 'refresh_token_hash' - 'token_hash'
             ELSE NULL END,
        CASE WHEN v_new IS NOT NULL
             THEN v_new - 'password_hash' - 'refresh_token_hash' - 'token_hash'
             ELSE NULL END
    );
 
    RETURN COALESCE(NEW, OLD);
END;
$$ LANGUAGE plpgsql;

-- Función de captura de domain events
CREATE OR REPLACE FUNCTION audit.capture_domain_event()
RETURNS TRIGGER AS $$
DECLARE
    v_record      JSONB;
    v_aggregate   UUID;
    v_org_id      UUID;
    v_event_name  TEXT;
BEGIN
    IF TG_OP = 'DELETE' THEN
        v_record    := to_jsonb(OLD);
        v_aggregate := OLD.id;
        v_org_id    := OLD.organization_id;
    ELSE
        v_record    := to_jsonb(NEW);
        v_aggregate := NEW.id;
        v_org_id    := NEW.organization_id;
    END IF;
 
    v_event_name := TG_TABLE_SCHEMA || '.' || TG_TABLE_NAME || '.' ||
                    LOWER(CASE TG_OP
                        WHEN 'INSERT' THEN 'created'
                        WHEN 'UPDATE' THEN 'updated'
                        WHEN 'DELETE' THEN 'deleted'
                    END);
 
    INSERT INTO audit.domain_events(
        event_name, aggregate_id, aggregate_type, organization_id, payload
    ) VALUES (
        v_event_name,
        v_aggregate,
        TG_TABLE_NAME,
        v_org_id,
        jsonb_build_object(
            'operation', TG_OP,
            'data',      v_record - 'password_hash' - 'refresh_token_hash',
            'timestamp', CURRENT_TIMESTAMP
        )
    );
 
    RETURN COALESCE(NEW, OLD);
END;
$$ LANGUAGE plpgsql;

-- Aplicar auditoría a entidades core
CREATE TRIGGER trg_audit_tickets
    AFTER INSERT OR UPDATE OR DELETE ON tickets.tickets
    FOR EACH ROW EXECUTE FUNCTION audit.log_entity_changes();
 
CREATE TRIGGER trg_audit_equipment
    AFTER INSERT OR UPDATE OR DELETE ON inventory.equipment
    FOR EACH ROW EXECUTE FUNCTION audit.log_entity_changes();
 
CREATE TRIGGER trg_audit_users
    AFTER INSERT OR UPDATE OR DELETE ON users.users
    FOR EACH ROW EXECUTE FUNCTION audit.log_entity_changes();
 
CREATE TRIGGER trg_domain_events_tickets
    AFTER INSERT OR UPDATE OR DELETE ON tickets.tickets
    FOR EACH ROW EXECUTE FUNCTION audit.capture_domain_event();
 
-- Índices audit
CREATE INDEX idx_audit_user        ON audit.audit_logs(user_id);
CREATE INDEX idx_audit_entity      ON audit.audit_logs(entity, entity_id);
CREATE INDEX idx_audit_org         ON audit.audit_logs(organization_id, created_at DESC);
CREATE INDEX idx_audit_action      ON audit.audit_logs(action);
CREATE INDEX idx_domain_status     ON audit.domain_events(status, created_at)
                                   WHERE status IN ('pending','retrying');
CREATE INDEX idx_domain_aggregate  ON audit.domain_events(aggregate_id);


-- ============================================================================
-- 12. ROW LEVEL SECURITY — AISLAMIENTO MULTI-TENANT
-- ============================================================================

-- Habilitar RLS
ALTER TABLE users.users              ENABLE ROW LEVEL SECURITY;
ALTER TABLE inventory.equipment      ENABLE ROW LEVEL SECURITY;
ALTER TABLE tickets.tickets          ENABLE ROW LEVEL SECURITY;
ALTER TABLE tickets.ticket_comments  ENABLE ROW LEVEL SECURITY;
ALTER TABLE files.files              ENABLE ROW LEVEL SECURITY;
ALTER TABLE notifications.notifications ENABLE ROW LEVEL SECURITY;
 
-- tickets.tickets: lectura por organización + rol/relación
CREATE POLICY policy_tickets_select ON tickets.tickets
    AS PERMISSIVE
    FOR SELECT
    USING (
        deleted_at IS NULL
        AND organization_id = app.get_current_organization_id()
        AND (
            app.get_current_role() IN ('admin', 'soporte', 'administrativo')
            OR created_by = app.get_current_user_id()
            OR assigned_to = app.get_current_user_id()
        )
    );

-- ✅ NUEVO: Políticas DENY explícitas para escritura en tickets
CREATE POLICY policy_tickets_insert_deny ON tickets.tickets
    FOR INSERT WITH CHECK (false);

CREATE POLICY policy_tickets_update_deny ON tickets.tickets
    FOR UPDATE USING (false);

CREATE POLICY policy_tickets_delete_deny ON tickets.tickets
    FOR DELETE USING (false);
 
-- tickets.ticket_comments: lectura si el ticket es visible + reglas internas
CREATE POLICY policy_comments_select ON tickets.ticket_comments
    AS PERMISSIVE
    FOR SELECT
    USING (
        deleted_at IS NULL
        AND EXISTS (
            SELECT 1
            FROM tickets.tickets t
            WHERE t.id = ticket_id
              AND t.organization_id = app.get_current_organization_id()
              AND t.deleted_at IS NULL
              AND (
                  app.get_current_role() IN ('admin', 'soporte', 'administrativo')
                  OR t.created_by = app.get_current_user_id()
                  OR t.assigned_to = app.get_current_user_id()
              )
        )
        AND (
            is_internal = FALSE
            OR app.get_current_role() IN ('admin', 'soporte')
        )
    );

-- ✅ NUEVO: Políticas DENY explícitas para escritura en comentarios
CREATE POLICY policy_comments_insert_deny ON tickets.ticket_comments
    FOR INSERT WITH CHECK (false);

CREATE POLICY policy_comments_update_deny ON tickets.ticket_comments
    FOR UPDATE USING (false);

CREATE POLICY policy_comments_delete_deny ON tickets.ticket_comments
    FOR DELETE USING (false);
 
-- users.users: lectura por organización
CREATE POLICY policy_users_select ON users.users
    AS PERMISSIVE
    FOR SELECT
    USING (
        deleted_at IS NULL
        AND organization_id = app.get_current_organization_id()
        AND (
            app.get_current_role() IN ('admin', 'soporte', 'administrativo')
            OR id = app.get_current_user_id()
        )
    );

-- ✅ NUEVO: Políticas DENY explícitas para escritura en usuarios
CREATE POLICY policy_users_insert_deny ON users.users
    FOR INSERT WITH CHECK (false);

CREATE POLICY policy_users_update_deny ON users.users
    FOR UPDATE USING (false);

CREATE POLICY policy_users_delete_deny ON users.users
    FOR DELETE USING (false);
 
-- inventory.equipment: lectura por organización
CREATE POLICY policy_equipment_select ON inventory.equipment
    AS PERMISSIVE
    FOR SELECT
    USING (
        deleted_at IS NULL
        AND organization_id = app.get_current_organization_id()
    );

-- ✅ NUEVO: Políticas DENY explícitas para escritura en equipos
CREATE POLICY policy_equipment_insert_deny ON inventory.equipment
    FOR INSERT WITH CHECK (false);

CREATE POLICY policy_equipment_update_deny ON inventory.equipment
    FOR UPDATE USING (false);

CREATE POLICY policy_equipment_delete_deny ON inventory.equipment
    FOR DELETE USING (false);
 
-- files.files: lectura por organización
CREATE POLICY policy_files_select ON files.files
    AS PERMISSIVE
    FOR SELECT
    USING (
        deleted_at IS NULL
        AND organization_id = app.get_current_organization_id()
    );

-- ✅ NUEVO: Políticas DENY explícitas para escritura en archivos
CREATE POLICY policy_files_insert_deny ON files.files
    FOR INSERT WITH CHECK (false);

CREATE POLICY policy_files_update_deny ON files.files
    FOR UPDATE USING (false);

CREATE POLICY policy_files_delete_deny ON files.files
    FOR DELETE USING (false);
 
-- notifications: lectura solo propias
CREATE POLICY policy_notifications_select ON notifications.notifications
    AS PERMISSIVE
    FOR SELECT
    USING (
        user_id = app.get_current_user_id()
    );

-- ✅ NUEVO: Políticas DENY explícitas para escritura en notificaciones
CREATE POLICY policy_notifications_insert_deny ON notifications.notifications
    FOR INSERT WITH CHECK (false);

CREATE POLICY policy_notifications_update_deny ON notifications.notifications
    FOR UPDATE USING (false);

CREATE POLICY policy_notifications_delete_deny ON notifications.notifications
    FOR DELETE USING (false);


-- ============================================================================
-- 13. SCHEMA: reports — Vistas materializadas enriquecidas
-- ============================================================================

-- Métricas diarias mejoradas
CREATE MATERIALIZED VIEW reports.ticket_metrics_daily AS
SELECT
    t.organization_id,
    DATE(t.created_at)                                                          AS date,
    COUNT(*)                                                                    AS total_created,
    COUNT(*) FILTER (WHERE ts.is_terminal = TRUE)                               AS total_closed,
    COUNT(*) FILTER (WHERE t.sla_breached = TRUE)                               AS sla_breached,
    COUNT(*) FILTER (WHERE t.closed_at <= t.sla_resolution_due_at
                      AND ts.is_terminal = TRUE)                                AS sla_met,
    ROUND(AVG(
        EXTRACT(EPOCH FROM (t.closed_at - t.created_at)) / 3600.0
    ) FILTER (WHERE t.closed_at IS NOT NULL)::NUMERIC, 2)                       AS avg_hours_to_close,
    ROUND(AVG(
        EXTRACT(EPOCH FROM (t.first_response_at - t.created_at)) / 3600.0
    ) FILTER (WHERE t.first_response_at IS NOT NULL)::NUMERIC, 2)              AS avg_hours_first_response,
    ROUND(AVG(t.satisfaction_score) FILTER (
        WHERE t.satisfaction_score IS NOT NULL
    )::NUMERIC, 2)                                                              AS avg_satisfaction,
    -- ✅ Nuevas métricas
    COUNT(*) FILTER (WHERE t.resolved_at IS NOT NULL)                           AS total_resolved,
    COUNT(*) FILTER (WHERE t.assigned_to IS NOT NULL)                           AS total_assigned,
    COUNT(*) FILTER (WHERE t.equipment_id IS NOT NULL)                          AS with_equipment
FROM tickets.tickets t
JOIN tickets.ticket_status ts ON ts.id = t.status_id
WHERE t.deleted_at IS NULL
GROUP BY t.organization_id, DATE(t.created_at)
WITH DATA;
 
CREATE UNIQUE INDEX idx_ticket_metrics_daily
    ON reports.ticket_metrics_daily(organization_id, date);
 
-- Rendimiento por agente (mejorado)
CREATE MATERIALIZED VIEW reports.agent_performance AS
SELECT
    u.id                                                                        AS user_id,
    u.first_name || ' ' || u.last_name                                          AS agent_name,
    u.organization_id,
    COUNT(DISTINCT t.id)                                                        AS total_assigned,
    COUNT(DISTINCT t.id) FILTER (WHERE ts.is_terminal = TRUE)                   AS total_resolved,
    ROUND(AVG(
        EXTRACT(EPOCH FROM (t.closed_at - t.created_at)) / 3600.0
    ) FILTER (WHERE t.closed_at IS NOT NULL)::NUMERIC, 2)                       AS avg_resolution_hours,
    COUNT(DISTINCT t.id) FILTER (
        WHERE t.closed_at IS NOT NULL
          AND t.closed_at <= t.sla_resolution_due_at
    )                                                                           AS sla_met,
    COUNT(DISTINCT t.id) FILTER (WHERE t.sla_breached = TRUE)                   AS sla_breached,
    ROUND(AVG(t.satisfaction_score) FILTER (
        WHERE t.satisfaction_score IS NOT NULL
    )::NUMERIC, 2)                                                              AS avg_satisfaction,
    -- ✅ Nuevas métricas
    MAX(t.created_at)                                                           AS last_assigned_at,
    COUNT(DISTINCT t.id) FILTER (WHERE t.created_at > CURRENT_DATE - 7)         AS last_7_days,
    COUNT(DISTINCT t.id) FILTER (WHERE t.first_response_at IS NOT NULL)         AS first_response_given
FROM users.users u
LEFT JOIN tickets.tickets t
    ON  t.assigned_to = u.id
    AND t.deleted_at  IS NULL
LEFT JOIN tickets.ticket_status ts ON ts.id = t.status_id
WHERE u.deleted_at IS NULL
  AND u.role_id IN (SELECT id FROM users.roles WHERE name IN ('soporte','admin'))
GROUP BY u.id, u.first_name, u.last_name, u.organization_id
WITH DATA;
 
CREATE UNIQUE INDEX idx_agent_performance_user
    ON reports.agent_performance(user_id);

CREATE INDEX idx_agent_performance_org
    ON reports.agent_performance(organization_id);
 
-- Vista de tickets activos
CREATE VIEW tickets.v_tickets_active AS
SELECT
    t.id,
    t.organization_id,
    t.ticket_number,
    t.title,
    t.created_by,
    t.assigned_to,
    t.equipment_id,
    ts.name                                                                     AS status,
    ts.is_terminal,
    tp.name                                                                     AS priority,
    tp.level                                                                    AS priority_level,
    tc.name                                                                     AS category,
    t.sla_response_due_at,
    t.sla_resolution_due_at,
    t.sla_breached,
    t.first_response_at,
    t.satisfaction_score,
    t.created_at,
    t.updated_at,
    ROUND(EXTRACT(EPOCH FROM (CURRENT_TIMESTAMP - t.created_at)) / 3600.0, 1)  AS age_hours
FROM  tickets.tickets t
JOIN  tickets.ticket_status   ts ON ts.id = t.status_id
JOIN  tickets.ticket_priority tp ON tp.id = t.priority_id
LEFT JOIN tickets.ticket_categories tc ON tc.id = t.category_id
WHERE t.deleted_at IS NULL
  AND ts.is_terminal = FALSE;
 
-- Vista de equipos activos
CREATE VIEW inventory.v_equipment_active AS
SELECT
    e.id,
    e.organization_id,
    e.name,
    e.serial_number,
    e.asset_tag,
    et.name     AS type,
    es.name     AS status,
    es.is_operational,
    e.brand,
    e.model,
    env.name    AS environment,
    b.name      AS block,
    e.warranty_until,
    e.purchase_date,
    e.created_at,
    CASE 
        WHEN e.warranty_until > CURRENT_DATE THEN 'active'
        WHEN e.warranty_until <= CURRENT_DATE THEN 'expired'
        ELSE 'unknown'
    END AS warranty_status
FROM  inventory.equipment        e
JOIN  inventory.equipment_types  et  ON et.id  = e.type_id
JOIN  inventory.equipment_status es  ON es.id  = e.status_id
LEFT JOIN inventory.environments env ON env.id = e.environment_id
LEFT JOIN inventory.blocks        b   ON b.id  = env.block_id
WHERE e.deleted_at IS NULL;


-- ============================================================================
-- 14. FUNCIONES DE MANTENIMIENTO AUTOMÁTICO
-- ============================================================================

-- Actualización de vistas materializadas
CREATE OR REPLACE FUNCTION reports.refresh_materialized_views()
RETURNS TEXT AS $$
BEGIN
    REFRESH MATERIALIZED VIEW reports.ticket_metrics_daily;
    REFRESH MATERIALIZED VIEW reports.agent_performance;
    RETURN 'Vistas materializadas actualizadas correctamente';
END;
$$ LANGUAGE plpgsql SECURITY DEFINER;

-- Función de mantenimiento completo
CREATE OR REPLACE FUNCTION maintenance.run_all()
RETURNS TEXT AS $$
DECLARE
    v_views_refreshed TEXT;
BEGIN
    v_views_refreshed := reports.refresh_materialized_views();
    RETURN format('Mantenimiento completado. %s', v_views_refreshed);
END;
$$ LANGUAGE plpgsql SECURITY DEFINER;


-- ============================================================================
-- 15. DOCUMENTACIÓN DE ORDEN DE TRIGGERS
-- ============================================================================

COMMENT ON TRIGGER trg_ticket_auto_timestamps ON tickets.tickets IS 
    'ORDEN CRÍTICO: Este trigger DEBE ejecutarse ANTES que trg_ticket_log_changes '
    'para que resolved_at y closed_at estén actualizados en el historial. '
    'Ejecución: BEFORE UPDATE - actualiza timestamps automáticos.';

COMMENT ON TRIGGER trg_ticket_log_changes ON tickets.tickets IS 
    'ORDEN CRÍTICO: Este trigger se ejecuta DESPUÉS de trg_ticket_auto_timestamps '
    'para capturar los timestamps actualizados en el historial. '
    'Ejecución: AFTER UPDATE - registra cambios campo a campo.';

COMMENT ON TRIGGER trg_ticket_sla_on_update ON tickets.tickets IS 
    'Recalcula SLA cuando cambia la prioridad. '
    'Ejecución: BEFORE UPDATE - debe ejecutarse antes de trg_ticket_auto_timestamps.';

COMMENT ON FUNCTION app.get_current_user_id() IS 
    'Lee app.current_user_id de la sesión. La app DEBE hacer SET LOCAL app.current_user_id = uuid '
    'al inicio de cada transacción para que auditoría y RLS funcionen correctamente.';

COMMENT ON FUNCTION tickets.next_ticket_number(UUID) IS 
    'Genera el próximo número de ticket secuencial por organización. '
    'Utiliza un contador en users.organizations para evitar race conditions.';


-- ============================================================================
-- 16. COMENTARIOS DE DOCUMENTACIÓN
-- ============================================================================

COMMENT ON SCHEMA app           IS 'Funciones de contexto para RLS (Supabase Auth + backend)';
COMMENT ON SCHEMA users         IS 'Perfiles, roles, permisos RBAC y organizaciones (multi-tenant)';
COMMENT ON SCHEMA inventory     IS 'Inventario de equipos, ambientes, bloques y mantenimiento';
COMMENT ON SCHEMA tickets       IS 'Core de mesa de ayuda: tickets, SLA, historial, comentarios y tags';
COMMENT ON SCHEMA files         IS 'Archivos adjuntos polimórficos (tickets, comentarios, mantenimiento, usuarios)';
COMMENT ON SCHEMA notifications IS 'Notificaciones multi-canal: in-app, email, push, WhatsApp';
COMMENT ON SCHEMA audit         IS 'Auditoría completa de cambios y eventos de dominio (CQRS-ready)';
COMMENT ON SCHEMA reports       IS 'Vistas materializadas para dashboards y métricas de rendimiento';
COMMENT ON SCHEMA maintenance   IS 'Funciones de mantenimiento y tareas programadas';
 
COMMENT ON TABLE  tickets.ticket_history IS
    'Historial campo a campo. changed_by = usuario real via app.get_current_user_id(). '
    'Sin FK para preservar datos históricos de entidades eliminadas. '
    'Almacena valores legibles (old_value/new_value) además de IDs para mantener contexto histórico.';
 
COMMENT ON TABLE  audit.domain_events IS
    'Eventos de dominio para integración con colas (Kafka, RabbitMQ) y arquitectura CQRS. '
    'El campo status permite reintentos con control de retry_count.';
 
COMMENT ON COLUMN tickets.tickets.sla_breached IS
    'TRUE si se superó sla_resolution_due_at sin resolved_at. '
    'Se recalcula en cada UPDATE via trigger trg_ticket_sla_on_update.';
 
COMMENT ON COLUMN tickets.tickets.ticket_number IS
    'Número secuencial por organización. Generado automáticamente via tickets.next_ticket_number() '
    'para evitar race conditions en entornos concurrentes.';
 
COMMENT ON COLUMN tickets.tickets.satisfaction_score IS
    'Puntuación de satisfacción del usuario (CSAT) de 1 a 5. '
    'Solo aplicable cuando el ticket está cerrado.';
 
COMMENT ON CONSTRAINT chk_sla_times ON tickets.sla_policies IS
    'Garantiza que el tiempo de resolución no sea menor que el tiempo de respuesta.';
 
COMMENT ON CONSTRAINT chk_satisfaction_score ON tickets.tickets IS
    'Valida que la puntuación de satisfacción esté entre 1 y 5.';


